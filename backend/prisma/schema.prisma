generator client {
  provider = "prisma-client-js"
}

// Configurado para PostgreSQL (Supabase) para ambiente de produção
datasource db {
  provider = "postgresql"
}

// Tabela de Usuários (Base para Pacientes e Profissionais)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String
  address   String
  role      String   // "PACIENTE" ou "PROFISSIONAL"
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relações
  patient       Patient?
  professional  Professional?
  notifications Notification[]
}

// Dados específicos do Paciente
model Patient {
  id        String   @id @default(uuid())
  cpf       String   @unique
  birthDate DateTime
  
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  anamnese     Anamnese?
  appointments Appointment[]
}

model Anamnese {
  id               String   @id @default(uuid())
  queixaPrincipal  String?
  hda              String?
  hppHf            String?
  habitos          String?
  medicamentos     String?
  alergias         String?
  cirurgiasPrevias String?
  vacinacao        String?
  observacoes      String?
  weightKg         Float?
  heightM          Float?

  patientId        String   @unique
  patient          Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

// Dados específicos do Profissional
model Professional {
  id             String   @id @default(uuid())
  councilNumber  String   @unique // CRM, CRP, etc.
  birthDate      DateTime
  specialty      String?  // Especialidade médica
  
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  curriculum     Curriculum?
  appointments   Appointment[]
  availabilities Availability[]
}

model Curriculum {
  id             String   @id @default(uuid())
  summary        String?
  education      String?
  experience     String?
  certifications String?

  professionalId String   @unique
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
}

// Novos Modelos para Funcionalidade Real

model Appointment {
  id              String   @id @default(uuid())
  patientId       String
  professionalId  String
  date            String   // ex: "2026-05-10"
  time            String   // ex: "14:00"
  mode            String   // "Presencial" ou "Teleatendimento"
  status          String   @default("pagamento_pendente") // "pagamento_pendente", "confirmada", "realizada", "cancelada"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  patient         Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  professional    Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  review          Review?
}

model Review {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  read        Boolean  @default(false)
  href        String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Availability {
  id             String   @id @default(uuid())
  professionalId String
  date           String   // ex: "2026-05-10"
  slots          String   // Array JSON serializado ou comma-separated ex: "08:00,09:00"

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, date])
}